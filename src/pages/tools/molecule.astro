---
import ToolLayout from '../../layouts/ToolLayout.astro';
import '../../styles/lab-hud.css';
---

<ToolLayout
  title="分子视界 · 3D 球棍与 DNA 螺旋"
  description="浏览器本地浏览水、简化咖啡因与 DNA 双螺旋球棍模型，可旋转与切换碱基对显示。"
  currentSlug="molecule"
>
  <h1 slot="header">分子视界</h1>
  <p class="intro">进入即自动旋转巡游 DNA → 多巴胺 → 5-羟色胺 → 咖啡因 → 水。拖动可手动旋转，滚轮缩放。</p>

  <link
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Oxanium:wght@500;700&display=swap"
    rel="stylesheet"
  />

  <div class="lab-hud lab-hero">
    <canvas id="mol-canvas" class="lab-hero-canvas lab-mol-canvas" aria-label="分子三维视图"></canvas>
    <p class="lab-hero-caption">
      <span id="mol-name">—</span> · 原子 <span class="lab-amber" id="mol-count">—</span>
      · <span id="mol-tour-note">自动巡游中</span>
    </p>
    <div class="lab-controls">
      <label>分子
        <select id="mol-select">
          <option value="dna">DNA 双螺旋</option>
          <option value="dopamine">多巴胺</option>
          <option value="serotonin">5-羟色胺</option>
          <option value="caffeine">咖啡因（简化）</option>
          <option value="water">水 H₂O</option>
        </select>
      </label>
      <button type="button" class="lab-btn secondary" id="mol-pairs">隐藏碱基对</button>
      <button type="button" class="lab-btn" id="mol-tour">暂停巡游</button>
    </div>
    <p class="lab-note">色例：C 灰 · H 白 · O 红 · N 蓝 · P 橙</p>
  </div>

  <div class="lab-related">
    <h2>相关</h2>
    <a href="/space">轻星图</a>
    <a href="/tools/audio-viz">音浪粒子</a>
    <a href="/tools/astro-today">今日星空</a>
  </div>
</ToolLayout>

<script>
  import { bootMolecule } from '../../scripts/molecule/main';
  bootMolecule();
</script>

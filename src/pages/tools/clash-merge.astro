---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Clash 节点合并"
  description="合并多个 Clash 订阅内容，自动去重整理节点。支持粘贴订阅文本或 Base64 内容。"
  currentSlug="clash-merge"
>
  <h1 slot="header">Clash 节点合并</h1>
  <p class="intro">
    将多个订阅内容合并为一个 Clash 配置片段。因浏览器跨域限制，请直接粘贴订阅内容（或 Base64 解码后的 YAML），每段之间用空行分隔。
  </p>

  <div class="tool-panel">
    <label for="clash-input">订阅内容（可粘贴多段，空行分隔）</label>
    <textarea id="clash-input" style="min-height:200px" placeholder="粘贴 Clash YAML 或 Base64 订阅内容..."></textarea>
    <div class="btn-row">
      <button class="btn" id="btn-clash-merge">合并去重</button>
      <button class="btn btn-secondary" id="btn-clash-copy">复制结果</button>
      <button class="btn btn-secondary" id="btn-clash-b64">输出 Base64 订阅</button>
    </div>
    <div id="clash-msg"></div>
  </div>

  <div class="tool-panel">
    <label for="clash-output">合并结果</label>
    <textarea id="clash-output" readonly style="min-height:200px" placeholder="合并后的节点列表"></textarea>
    <p id="clash-stats" style="margin-top:8px;color:var(--muted);font-size:0.9rem"></p>
  </div>

  <section class="section">
    <h2>使用说明</h2>
    <ul>
      <li>从各免费节点源复制订阅内容，粘贴到上方输入框</li>
      <li>多段内容用空行分隔，工具会自动解析并去重</li>
      <li>去重依据：节点 name + server + port 组合</li>
      <li>订阅 URL 因跨域无法直接抓取，请手动复制订阅内容</li>
    </ul>
  </section>
</ToolLayout>

<script>
  const input = document.getElementById('clash-input') as HTMLTextAreaElement;
  const output = document.getElementById('clash-output') as HTMLTextAreaElement;
  const stats = document.getElementById('clash-stats')!;
  const msg = document.getElementById('clash-msg')!;

  function showMsg(text: string, type: 'error' | 'success') {
    msg.className = `msg ${type}`;
    msg.textContent = text;
  }

  // 尝试 Base64 解码
  function tryDecode(content: string): string {
    const trimmed = content.trim();
    if (trimmed.startsWith('proxies:') || trimmed.startsWith('- ')) return trimmed;
    try {
      const decoded = atob(trimmed.replace(/\s/g, ''));
      if (decoded.includes('proxies:') || decoded.includes('server:')) return decoded;
    } catch {}
    return trimmed;
  }

  // 从 YAML 片段提取 proxy 条目（ponytail: 简单行解析，复杂嵌套 YAML 需换 js-yaml）
  function extractProxies(yaml: string): string[] {
    const blocks: string[] = [];
    const lines = yaml.split('\n');
    let current: string[] = [];
    let inProxy = false;

    for (const line of lines) {
      if (/^\s*-\s+\{/.test(line)) {
        // 单行 JSON 风格 proxy
        if (current.length) blocks.push(current.join('\n'));
        current = [line.trim()];
        inProxy = false;
        blocks.push(current.join('\n'));
        current = [];
        continue;
      }
      if (/^\s*-\s+name:/.test(line)) {
        if (current.length) blocks.push(current.join('\n'));
        current = [line];
        inProxy = true;
      } else if (inProxy && /^\s+\w/.test(line)) {
        current.push(line);
      } else if (inProxy && line.trim() == '') {
        if (current.length) blocks.push(current.join('\n'));
        current = [];
        inProxy = false;
      }
    }
    if (current.length) blocks.push(current.join('\n'));
    return blocks.filter(Boolean);
  }

  function proxyKey(block: string): string {
    const name = block.match(/name:\s*['"]?([^'"\n]+)/)?.[1]?.trim() || '';
    const server = block.match(/server:\s*['"]?([^'"\n]+)/)?.[1]?.trim() || '';
    const port = block.match(/port:\s*(\d+)/)?.[1] || '';
    return `${name}|${server}|${port}`;
  }

  document.getElementById('btn-clash-merge')!.addEventListener('click', () => {
    const raw = input.value.trim();
    if (!raw) {
      showMsg('请粘贴订阅内容', 'error');
      return;
    }

    const sections = raw.split(/\n\s*\n/).map(tryDecode);
    const seen = new Set<string>();
    const merged: string[] = [];

    for (const section of sections) {
      for (const proxy of extractProxies(section)) {
        const key = proxyKey(proxy);
        if (!seen.has(key)) {
          seen.add(key);
          merged.push(proxy);
        }
      }
    }

    if (merged.length == 0) {
      showMsg('未解析到节点，请检查内容格式', 'error');
      return;
    }

    output.value = `proxies:\n${merged.join('\n')}`;
    stats.textContent = `共合并 ${merged.length} 个节点（已去重）`;
    showMsg('合并完成', 'success');
  });

  document.getElementById('btn-clash-copy')!.addEventListener('click', async () => {
    if (!output.value) return;
    await navigator.clipboard.writeText(output.value);
    showMsg('已复制', 'success');
  });

  document.getElementById('btn-clash-b64')!.addEventListener('click', () => {
    if (!output.value) {
      showMsg('请先合并', 'error');
      return;
    }
    output.value = btoa(unescape(encodeURIComponent(output.value)));
    showMsg('已转为 Base64 订阅格式', 'success');
  });
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout title="图片合并" description="在线多张图片拼接，支持等宽/等高对齐，纯浏览器处理。" currentSlug="image-merge">
  <h1 slot="header">图片合并</h1>
  <p class="intro">横向拼接建议等高对齐，纵向拼接建议等宽对齐。</p>

  <div class="tool-panel">
    <label for="merge-files">选择图片（可多选）</label>
    <input type="file" id="merge-files" accept="image/*" multiple />
    <div style="margin-top:14px;display:grid;grid-template-columns:1fr 1fr;gap:12px">
      <div>
        <label for="merge-direction">拼接方向</label>
        <select id="merge-direction" style="margin-top:8px">
          <option value="horizontal">横向（左右）</option>
          <option value="vertical">纵向（上下）</option>
        </select>
      </div>
      <div>
        <label for="merge-align">尺寸对齐</label>
        <select id="merge-align" style="margin-top:8px">
          <option value="none">不对齐（原尺寸）</option>
          <option value="equal-height" selected>等高</option>
          <option value="equal-width">等宽</option>
        </select>
      </div>
    </div>
    <div class="btn-row">
      <button class="btn" id="btn-merge">开始合并</button>
      <a class="btn btn-secondary" id="btn-download" download="merged.png" style="display:none">下载图片</a>
    </div>
    <div id="merge-msg"></div>
  </div>

  <div class="tool-panel">
    <label>预览</label>
    <canvas id="merge-canvas" style="max-width:100%;border:1px solid var(--border);border-radius:6px;margin-top:8px"></canvas>
  </div>
</ToolLayout>

<script>
  const fileInput = document.getElementById('merge-files') as HTMLInputElement;
  const direction = document.getElementById('merge-direction') as HTMLSelectElement;
  const align = document.getElementById('merge-align') as HTMLSelectElement;
  const canvas = document.getElementById('merge-canvas') as HTMLCanvasElement;
  const download = document.getElementById('btn-download') as HTMLAnchorElement;
  const msg = document.getElementById('merge-msg')!;

  function showMsg(text: string, type: 'error' | 'success') {
    msg.className = `msg ${type}`;
    msg.textContent = text;
  }

  direction.addEventListener('change', () => {
    align.value = direction.value == 'horizontal' ? 'equal-height' : 'equal-width';
  });

  function loadImage(file: File): Promise<HTMLImageElement> {
    return new Promise((resolve, reject) => {
      const img = new Image();
      img.onload = () => resolve(img);
      img.onerror = reject;
      img.src = URL.createObjectURL(file);
    });
  }

  function calcSizes(images: HTMLImageElement[], alignMode: string) {
    const maxW = Math.max(...images.map((i) => i.width));
    const maxH = Math.max(...images.map((i) => i.height));

    return images.map((img) => {
      if (alignMode == 'equal-height') {
        const scale = maxH / img.height;
        return { w: Math.round(img.width * scale), h: maxH };
      }
      if (alignMode == 'equal-width') {
        const scale = maxW / img.width;
        return { w: maxW, h: Math.round(img.height * scale) };
      }
      return { w: img.width, h: img.height };
    });
  }

  document.getElementById('btn-merge')!.addEventListener('click', async () => {
    const files = fileInput.files;
    if (!files || files.length < 2) {
      showMsg('请至少选择 2 张图片', 'error');
      return;
    }

    try {
      const images = await Promise.all(Array.from(files).map(loadImage));
      const isH = direction.value == 'horizontal';
      const sizes = calcSizes(images, align.value);

      const totalW = isH ? sizes.reduce((s, x) => s + x.w, 0) : Math.max(...sizes.map((x) => x.w));
      const totalH = isH ? Math.max(...sizes.map((x) => x.h)) : sizes.reduce((s, x) => s + x.h, 0);

      canvas.width = totalW;
      canvas.height = totalH;
      const ctx = canvas.getContext('2d')!;
      ctx.fillStyle = '#ffffff';
      ctx.fillRect(0, 0, totalW, totalH);

      let offset = 0;
      images.forEach((img, i) => {
        const { w, h } = sizes[i];
        const yOff = isH ? Math.floor((totalH - h) / 2) : offset;
        const xOff = isH ? offset : Math.floor((totalW - w) / 2);
        ctx.drawImage(img, xOff, yOff, w, h);
        offset += isH ? w : h;
      });

      download.href = canvas.toDataURL('image/png');
      download.style.display = 'inline-block';
      showMsg(`合并完成，共 ${images.length} 张`, 'success');
    } catch {
      showMsg('图片加载失败', 'error');
    }
  });
</script>

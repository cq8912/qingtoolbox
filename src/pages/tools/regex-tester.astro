---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="正则表达式在线测试"
  description="正则表达式在线测试工具，支持 JavaScript 正则 flags、匹配列表、捕获组与替换预览，浏览器本地处理。"
  currentSlug="regex-tester"
>
  <h1 slot="header">正则表达式测试</h1>
  <p class="intro">输入表达式和测试文本，查看匹配结果、捕获组和替换预览。</p>

  <div class="tool-panel">
    <label>常用示例</label>
    <div class="regex-demo-list">
      <button class="regex-demo-btn" type="button" data-demo="email">邮箱</button>
      <button class="regex-demo-btn" type="button" data-demo="phone">手机号</button>
      <button class="regex-demo-btn" type="button" data-demo="url">URL</button>
      <button class="regex-demo-btn" type="button" data-demo="date">日期</button>
      <button class="regex-demo-btn" type="button" data-demo="ipv4">IPv4</button>
      <button class="regex-demo-btn" type="button" data-demo="id">身份证号</button>
    </div>
    <div class="regex-row">
      <div>
        <label for="regex-pattern">表达式</label>
        <input type="text" id="regex-pattern" placeholder="例如：\\b\\w+@\\w+\\.com\\b" />
      </div>
      <div>
        <label for="regex-flags">Flags</label>
        <input type="text" id="regex-flags" value="g" placeholder="gimuy" />
      </div>
    </div>
    <label for="regex-text">测试文本</label>
    <textarea id="regex-text" class="json-editor" placeholder="输入要测试的文本"></textarea>
    <label for="regex-replace" class="field-label regex-replace-label">替换为（可选）</label>
    <input type="text" id="regex-replace" placeholder="支持 $1、$2 捕获组" />
    <div class="btn-row">
      <button class="btn" id="btn-run">测试</button>
      <button class="btn btn-secondary" id="btn-copy-replace">复制替换结果</button>
      <button class="btn btn-secondary" id="btn-clear">清空</button>
    </div>
    <div id="regex-msg"></div>
  </div>

  <div class="json-split">
    <div class="tool-panel">
      <label>匹配结果</label>
      <div class="result-box" id="regex-matches">等待测试</div>
    </div>
    <div class="tool-panel">
      <label for="regex-output">替换预览</label>
      <textarea id="regex-output" class="json-editor output-readonly" readonly placeholder="替换结果将显示在这里"></textarea>
    </div>
  </div>
</ToolLayout>

<script>
  const pattern = document.getElementById('regex-pattern') as HTMLInputElement;
  const flags = document.getElementById('regex-flags') as HTMLInputElement;
  const text = document.getElementById('regex-text') as HTMLTextAreaElement;
  const replace = document.getElementById('regex-replace') as HTMLInputElement;
  const matches = document.getElementById('regex-matches')!;
  const output = document.getElementById('regex-output') as HTMLTextAreaElement;
  const msg = document.getElementById('regex-msg')!;
  const demos: Record<string, { pattern: string; flags: string; text: string; replace: string }> = {
    email: {
      pattern: String.raw`[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}`,
      flags: 'g',
      text: '联系邮箱：hello@example.com、test.user+tag@qq.com，错误示例：abc@',
      replace: '[邮箱]',
    },
    phone: {
      pattern: String.raw`1[3-9]\d{9}`,
      flags: 'g',
      text: '手机号：13800138000、19912345678，座机：010-88888888',
      replace: '[手机号]',
    },
    url: {
      pattern: String.raw`https?:\/\/[^\s]+`,
      flags: 'g',
      text: '官网 https://tools.cqzzz.top ，文档 http://example.com/a?b=1',
      replace: '[链接]',
    },
    date: {
      pattern: String.raw`\b\d{4}[-/](0?[1-9]|1[0-2])[-/](0?[1-9]|[12]\d|3[01])\b`,
      flags: 'g',
      text: '日期：2026-06-18、2026/6/8，错误：2026-99-99',
      replace: '$1月$2日',
    },
    ipv4: {
      pattern: String.raw`\b((25[0-5]|2[0-4]\d|1?\d?\d)\.){3}(25[0-5]|2[0-4]\d|1?\d?\d)\b`,
      flags: 'g',
      text: '内网 192.168.1.1，DNS 8.8.8.8，错误 999.1.1.1',
      replace: '[IP]',
    },
    id: {
      pattern: String.raw`\b\d{17}[\dXx]\b`,
      flags: 'g',
      text: '示例：11010519491231002X、440524188001010014',
      replace: '[身份证]',
    },
  };

  function esc(s: string) {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  }

  function showMsg(text: string, type: 'error' | 'success') {
    msg.className = `msg ${type}`;
    msg.textContent = text;
  }

  function run() {
    try {
      const safeFlags = Array.from(new Set(flags.value.split(''))).join('');
      const re = new RegExp(pattern.value, safeFlags.includes('g') ? safeFlags : `${safeFlags}g`);
      const found = Array.from(text.value.matchAll(re));
      output.value = text.value.replace(re, replace.value);
      if (!found.length) {
        matches.textContent = '未匹配到内容';
        showMsg('测试完成：0 个匹配', 'success');
        return;
      }
      matches.innerHTML = found.map((m, i) => {
        const groups = m.slice(1).map((g, n) => `<div class="match-group">$${n + 1}: <code>${esc(g ?? '')}</code></div>`).join('');
        return `<div class="match-item"><strong>#${i + 1}</strong> <code>${esc(m[0])}</code><span>位置 ${m.index}</span>${groups}</div>`;
      }).join('');
      showMsg(`测试完成：${found.length} 个匹配`, 'success');
    } catch (e) {
      matches.textContent = '正则表达式无效';
      output.value = '';
      showMsg(`表达式错误：${(e as Error).message}`, 'error');
    }
  }

  document.getElementById('btn-run')!.addEventListener('click', run);
  document.querySelectorAll('.regex-demo-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const demo = demos[(btn as HTMLElement).dataset.demo || ''];
      if (!demo) return;
      pattern.value = demo.pattern;
      flags.value = demo.flags;
      text.value = demo.text;
      replace.value = demo.replace;
      run();
    });
  });
  document.getElementById('btn-copy-replace')!.addEventListener('click', async () => {
    if (!output.value) return;
    await navigator.clipboard.writeText(output.value);
    showMsg('已复制替换结果', 'success');
  });
  document.getElementById('btn-clear')!.addEventListener('click', () => {
    pattern.value = '';
    text.value = '';
    replace.value = '';
    output.value = '';
    matches.textContent = '等待测试';
    msg.textContent = '';
    msg.className = '';
  });
</script>

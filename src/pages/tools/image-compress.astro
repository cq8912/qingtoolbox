---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout title="图片压缩" description="在线图片压缩，支持质量、尺寸比例调节，浏览器本地处理。" currentSlug="image-compress">
  <h1 slot="header">图片压缩</h1>
  <p class="intro">点击原图区域上传，调节质量与尺寸，实时预览压缩效果。</p>

  <div class="compress-workspace">
    <div class="compress-panel">
      <div class="field-label">原图（点击上传）</div>
      <label class="img-slot img-slot-upload" id="slot-original-wrap">
        <input type="file" id="compress-file" accept="image/*" />
        <span id="slot-original-placeholder">点击上传图片</span>
        <img id="img-original-preview" alt="" style="display:none;max-width:100%;max-height:100%;object-fit:contain" />
      </label>
      <div class="img-meta" id="meta-original">—</div>
    </div>

    <div class="compress-panel compress-controls">
      <div>
        <label class="field-label">质量 <span class="range-val" id="quality-val">80%</span></label>
        <div class="range-row">
          <input type="range" id="compress-quality" min="10" max="100" value="80" />
        </div>
      </div>
      <div>
        <label class="field-label">尺寸比例 <span class="range-val" id="scale-val">100%</span></label>
        <div class="range-row">
          <input type="range" id="compress-scale" min="10" max="100" value="100" />
        </div>
      </div>
      <div class="size-input-row">
        <div>
          <label class="field-label" for="size-w">宽 (px)</label>
          <input type="number" id="size-w" min="1" placeholder="自动" />
        </div>
        <div>
          <label class="field-label" for="size-h">高 (px)</label>
          <input type="number" id="size-h" min="1" placeholder="自动" />
        </div>
      </div>
      <div>
        <label class="field-label" for="compress-format">输出格式</label>
        <select id="compress-format">
          <option value="image/jpeg">JPEG</option>
          <option value="image/webp">WebP</option>
          <option value="image/png">PNG</option>
        </select>
      </div>
      <div class="btn-row compress-btn-row">
        <button class="btn" id="btn-compress">压缩</button>
        <a class="btn btn-secondary" id="btn-compress-dl" download="compressed.jpg" style="display:none">下载</a>
      </div>
      <div id="compress-msg"></div>
    </div>

    <div class="compress-panel">
      <div class="field-label">压缩后</div>
      <div class="img-slot" id="slot-compressed"><span>等待压缩</span></div>
      <div class="img-meta" id="meta-compressed">—</div>
    </div>
  </div>

  <div class="compress-summary" id="compress-summary" style="display:none"></div>
</ToolLayout>

<script>
  const fileInput = document.getElementById('compress-file') as HTMLInputElement;
  const slotWrap = document.getElementById('slot-original-wrap')!;
  const placeholder = document.getElementById('slot-original-placeholder')!;
  const imgPreview = document.getElementById('img-original-preview') as HTMLImageElement;
  const quality = document.getElementById('compress-quality') as HTMLInputElement;
  const qualityVal = document.getElementById('quality-val')!;
  const scale = document.getElementById('compress-scale') as HTMLInputElement;
  const scaleVal = document.getElementById('scale-val')!;
  const sizeW = document.getElementById('size-w') as HTMLInputElement;
  const sizeH = document.getElementById('size-h') as HTMLInputElement;
  const format = document.getElementById('compress-format') as HTMLSelectElement;
  const slotCompressed = document.getElementById('slot-compressed')!;
  const metaOriginal = document.getElementById('meta-original')!;
  const metaCompressed = document.getElementById('meta-compressed')!;
  const summary = document.getElementById('compress-summary')!;
  const download = document.getElementById('btn-compress-dl') as HTMLAnchorElement;
  const msg = document.getElementById('compress-msg')!;

  let currentFile: File | null = null;
  let origW = 0, origH = 0;
  let debounceTimer: ReturnType<typeof setTimeout>;
  let lockRatio = true;

  function fmtSize(bytes: number) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / 1024 / 1024).toFixed(2) + ' MB';
  }

  function showMsg(text: string, type: 'error' | 'success') {
    msg.className = `msg ${type}`;
    msg.textContent = text;
  }

  function syncSizeInputs(w: number, h: number) {
    sizeW.value = String(w);
    sizeH.value = String(h);
  }

  function updateScaleFromSize(w: number) {
    if (!origW) return;
    const pct = Math.round((w / origW) * 100);
    scale.value = String(Math.min(100, Math.max(10, pct)));
    scaleVal.textContent = scale.value + '%';
  }

  function getOutputSize(natW: number, natH: number) {
    const wIn = Number(sizeW.value);
    const hIn = Number(sizeH.value);
    if (wIn > 0 && hIn > 0) return { w: wIn, h: hIn };
    if (wIn > 0) return { w: wIn, h: Math.round(natH * (wIn / natW)) };
    if (hIn > 0) return { w: Math.round(natW * (hIn / natH)), h: hIn };
    const ratio = Number(scale.value) / 100;
    return { w: Math.round(natW * ratio), h: Math.round(natH * ratio) };
  }

  function doCompress() {
    if (!currentFile) return;
    const img = new Image();
    img.onload = () => {
      const { w, h } = getOutputSize(img.width, img.height);
      syncSizeInputs(w, h);

      const canvas = document.createElement('canvas');
      canvas.width = w;
      canvas.height = h;
      const ctx = canvas.getContext('2d')!;
      ctx.drawImage(img, 0, 0, w, h);

      const mime = format.value;
      const q = Number(quality.value) / 100;
      const dataUrl = canvas.toDataURL(mime, q);

      slotCompressed.innerHTML = `<img src="${dataUrl}" alt="" style="max-width:100%;max-height:100%;object-fit:contain" />`;
      download.href = dataUrl;
      const ext = mime.split('/')[1] == 'jpeg' ? 'jpg' : mime.split('/')[1];
      download.download = `compressed.${ext}`;
      download.style.display = 'inline-block';

      const base64 = dataUrl.split(',')[1];
      const compressedSize = Math.round((base64.length * 3) / 4);
      const saved = currentFile ? Math.round((1 - compressedSize / currentFile.size) * 100) : 0;

      metaOriginal.textContent = `${origW}×${origH} px · ${fmtSize(currentFile!.size)}`;
      metaCompressed.textContent = `${w}×${h} px · 约 ${fmtSize(compressedSize)}`;
      summary.style.display = 'flex';
      summary.innerHTML = `
        <span>原图：<strong>${fmtSize(currentFile!.size)}</strong> · ${origW}×${origH}</span>
        <span>压缩后：<strong>${fmtSize(compressedSize)}</strong> · ${w}×${h}</span>
        <span>节省：<strong>${saved}%</strong></span>
        <span>质量 ${quality.value}% · ${ext.toUpperCase()}</span>
      `;
      showMsg('压缩完成', 'success');
    };
    img.src = URL.createObjectURL(currentFile);
  }

  function onFileSelect(file: File) {
    currentFile = file;
    const img = new Image();
    img.onload = () => {
      origW = img.width;
      origH = img.height;
      placeholder.style.display = 'none';
      imgPreview.src = img.src;
      imgPreview.style.display = 'block';
      syncSizeInputs(origW, origH);
      scale.value = '100';
      scaleVal.textContent = '100%';
      metaOriginal.textContent = `${origW}×${origH} px · ${fmtSize(file.size)}`;
      doCompress();
    };
    img.src = URL.createObjectURL(file);
  }

  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) onFileSelect(file);
  });

  slotWrap.addEventListener('dragover', (e) => e.preventDefault());
  slotWrap.addEventListener('drop', (e) => {
    e.preventDefault();
    const file = e.dataTransfer?.files?.[0];
    if (file && file.type.startsWith('image/')) onFileSelect(file);
  });

  quality.addEventListener('input', () => {
    qualityVal.textContent = quality.value + '%';
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(doCompress, 300);
  });

  scale.addEventListener('input', () => {
    scaleVal.textContent = scale.value + '%';
    if (origW && origH) {
      const w = Math.round(origW * Number(scale.value) / 100);
      const h = Math.round(origH * Number(scale.value) / 100);
      syncSizeInputs(w, h);
    }
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(doCompress, 300);
  });

  sizeW.addEventListener('input', () => {
    const w = Number(sizeW.value);
    if (!w || !origW) return;
    if (lockRatio && origH) {
      const h = Math.round(origH * (w / origW));
      sizeH.value = String(h);
    }
    updateScaleFromSize(w);
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(doCompress, 300);
  });

  sizeH.addEventListener('input', () => {
    const h = Number(sizeH.value);
    if (!h || !origH) return;
    if (lockRatio && origW) {
      const w = Math.round(origW * (h / origH));
      sizeW.value = String(w);
      updateScaleFromSize(w);
    }
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(doCompress, 300);
  });

  format.addEventListener('change', doCompress);
  document.getElementById('btn-compress')!.addEventListener('click', doCompress);
</script>

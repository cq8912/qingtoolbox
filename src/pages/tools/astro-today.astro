---
import ToolLayout from '../../layouts/ToolLayout.astro';
import '../../styles/lab-hud.css';
---

<ToolLayout
  title="今日星空与月相 · 本地升落时刻"
  description="按你的位置告诉你今晚月亮几分圆、太阳何时落、哪颗亮行星在天上。浏览器本地演算，无需上传。"
  currentSlug="astro-today"
>
  <h1 slot="header">今日星空</h1>
  <p class="intro">出门看天前瞄一眼：今晚月相、日月升落，以及此刻哪颗行星在地平线上。</p>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Oxanium:wght@500;700&display=swap"
    rel="stylesheet"
  />

  <div class="lab-hud lab-hero" id="astro-root">
    <p class="lab-story">
      <strong>这页干嘛：</strong>根据你的经纬度，算出<strong>今晚月亮什么样</strong>、<strong>太阳几点落</strong>，以及<strong>金星火星等现在能不能看见</strong>。
    </p>

    <canvas id="astro-moon" class="lab-hero-canvas" aria-label="月相主视图"></canvas>
    <p class="lab-hero-caption">
      <span class="lab-amber lab-phase-big" id="astro-phase-name">—</span>
      · 照明 <span id="astro-illum">—</span>
      · 此刻 <span id="astro-now">—</span>
    </p>

    <div class="lab-cards" aria-label="今晚要点">
      <div class="lab-card">
        <span class="lab-card-k">今晚月相</span>
        <span class="lab-card-v amber" id="astro-card-phase">—</span>
      </div>
      <div class="lab-card">
        <span class="lab-card-k">日落</span>
        <span class="lab-card-v" id="astro-card-sunset">—</span>
      </div>
      <div class="lab-card">
        <span class="lab-card-k">此刻最亮行星</span>
        <span class="lab-card-v" id="astro-card-planet">—</span>
      </div>
    </div>

    <details class="lab-details" open>
      <summary>观测点与升落明细</summary>
      <p class="lab-note" id="astro-geo-note">初始化中…</p>
      <p class="lab-note">坐标 <span id="astro-pos">—</span></p>
      <div class="lab-controls">
        <label>纬度 <input type="number" id="astro-lat" step="0.0001" /></label>
        <label>经度 <input type="number" id="astro-lon" step="0.0001" /></label>
        <button type="button" class="lab-btn" id="astro-apply">应用</button>
        <button type="button" class="lab-btn secondary" id="astro-gps">定位</button>
        <a class="lab-btn secondary" href="/space">打开轻星图</a>
      </div>
      <table>
        <thead>
          <tr><th>天体</th><th>升起</th><th>落下</th></tr>
        </thead>
        <tbody>
          <tr><td>太阳</td><td id="astro-sun-rise">—</td><td id="astro-sun-set">—</td></tr>
          <tr><td>月球</td><td id="astro-moon-rise">—</td><td id="astro-moon-set">—</td></tr>
        </tbody>
      </table>
      <table>
        <thead>
          <tr><th>行星</th><th>高度</th><th>朝哪边看</th><th>状态</th></tr>
        </thead>
        <tbody id="astro-planets"></tbody>
      </table>
    </details>
  </div>

  <div class="lab-related">
    <h2>相关</h2>
    <a href="/space">轻星图</a>
    <a href="/tools/orbit-lab">轨道实验</a>
    <a href="/tools/sat-pass">卫星过顶</a>
  </div>
</ToolLayout>

<script>
  import { bootAstroToday } from '../../scripts/astro-today/main';
  bootAstroToday();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout title="JSON 在线查看器" description="JSON 格式化校验工具：在线修复、压缩、树形查看，支持大文本，浏览器本地处理。" currentSlug="json-viewer">
  <h1 slot="header">JSON 在线查看器</h1>
  <p class="intro">粘贴 JSON，格式化失败时自动尝试修复，输出为可折叠树形视图。</p>

  <div class="json-workbench" id="json-workbench">
  <div class="json-split">
    <div class="tool-panel">
      <label for="json-input">输入</label>
      <textarea id="json-input" class="json-editor" placeholder='{"name": "示例"}'></textarea>
      <p class="field-hint" id="json-input-stats">0 字符 · 0 行</p>
      <div class="btn-row">
        <button class="btn" id="btn-format">格式化</button>
        <button class="btn btn-secondary" id="btn-minify">压缩</button>
        <button class="btn btn-secondary" id="btn-validate">校验</button>
        <button class="btn btn-secondary" id="btn-clear">清空</button>
      </div>
      <div id="json-msg"></div>
    </div>
    <div class="tool-panel">
      <div class="json-panel-header">
        <label>输出</label>
        <div class="json-header-actions">
          <button type="button" class="btn btn-secondary btn-sm" id="btn-toggle-tree">全部展开</button>
          <button type="button" class="btn btn-secondary btn-sm" id="btn-json-full">页面全屏</button>
        </div>
      </div>
      <div class="json-output-wrap json-formatter-host json-style-bracket" id="json-output">
        <span class="json-placeholder">结果将显示在这里</span>
      </div>
      <p class="field-hint" id="json-output-stats">0 字符 · 0 行</p>
      <div class="json-output-foot">
        <div class="json-style-switch" id="json-style-switch">
          <button type="button" class="btn btn-secondary btn-sm active" data-style="bracket">括号</button>
          <button type="button" class="btn btn-secondary btn-sm" data-style="guide">层级线</button>
          <button type="button" class="btn btn-secondary btn-sm" data-style="plain">简洁</button>
          <button type="button" class="btn btn-secondary btn-sm" data-style="code">代码风</button>
        </div>
      </div>
    </div>
  </div>
  </div>
</ToolLayout>

<script>
  import { jsonrepair } from 'jsonrepair';
  import JSONFormatter from 'json-formatter-js';

  const input = document.getElementById('json-input') as HTMLTextAreaElement;
  const output = document.getElementById('json-output')!;
  const msg = document.getElementById('json-msg')!;
  const inputStats = document.getElementById('json-input-stats')!;
  const outputStats = document.getElementById('json-output-stats')!;
  const toggleBtn = document.getElementById('btn-toggle-tree')!;
  const fullBtn = document.getElementById('btn-json-full')!;
  const styleSwitch = document.getElementById('json-style-switch')!;
  const workbench = document.getElementById('json-workbench')!;

  let lastData: any = null;
  let treeExpanded = false;
  let previewTimer: number | null = null;
  let currentStyle: 'bracket' | 'guide' | 'plain' | 'code' = 'bracket';

  const pathConfig = {
    expandPaths: [
      'chatData.tools.*.function',
      'chatData.tools.*.function.name',
      'chatData.tools.*.function.description',
    ],
    collapsePaths: [
      '*.parameters',
      '*.properties',
      '*.enum',
      '*.required',
    ],
  };

  function showMsg(text: string, type: 'error' | 'success') {
    msg.className = `msg ${type}`;
    msg.textContent = text;
  }

  function updateStats(text: string, statsEl: HTMLElement) {
    statsEl.textContent = `${text.length} 字符 · ${text ? text.split('\n').length : 0} 行`;
  }

  function getErrorLine(raw: string, err: Error) {
    const m = err.message.match(/position\s+(\d+)/i);
    if (!m) return null;
    return raw.slice(0, Number(m[1])).split('\n').length;
  }

  function renderTree(data: any) {
    lastData = data;
    output.innerHTML = '';
    const openDepth = treeExpanded ? 99 : 1;
    const formatter = new JSONFormatter(data, openDepth, {
      hoverPreviewEnabled: false,
      theme: 'light',
      exposePath: true,
    });
    output.appendChild(formatter.render());
    applyPathRules();
    applyOutputStyle();
    const text = JSON.stringify(data, null, 2);
    updateStats(text, outputStats);
    toggleBtn.textContent = treeExpanded ? '全部折叠' : '全部展开';
  }

  function renderEmpty() {
    lastData = null;
    output.innerHTML = '<span class="json-placeholder">结果将显示在这里</span>';
    updateStats('', outputStats);
  }

  function parseOrRepair(raw: string) {
    try {
      return { data: JSON.parse(raw), repaired: false };
    } catch (e) {
      const err = e as Error;
      const line = getErrorLine(raw, err);
      const errDesc = line ? `第 ${line} 行附近：${err.message}` : err.message;
      try {
        return { data: JSON.parse(jsonrepair(raw)), repaired: true, errDesc };
      } catch {
        throw new Error(errDesc + ' → 自动修复失败，请人工检查');
      }
    }
  }

  function runFormat(pretty: boolean) {
    const raw = input.value.trim();
    if (!raw) {
      showMsg('请输入 JSON 内容', 'error');
      return;
    }
    try {
      const { data, repaired, errDesc } = parseOrRepair(raw);
      if (pretty) {
        input.value = JSON.stringify(data, null, 2);
        updateStats(input.value, inputStats);
        renderTree(data);
      } else {
        const min = JSON.stringify(data);
        output.innerHTML = `<pre class="json-minify">${min}</pre>`;
        lastData = data;
        updateStats(min, outputStats);
      }
      input.classList.remove('error-line');
      if (repaired && errDesc) showMsg(`${errDesc} → 已自动修复`, 'success');
      else showMsg(pretty ? '格式化成功' : '压缩成功', 'success');
    } catch (e) {
      input.classList.add('error-line');
      showMsg((e as Error).message, 'error');
      renderEmpty();
    }
  }

  function scheduleAutoPreview() {
    if (previewTimer) window.clearTimeout(previewTimer);
    previewTimer = window.setTimeout(() => {
      const raw = input.value.trim();
      if (!raw) {
        renderEmpty();
        msg.textContent = '';
        msg.className = '';
        return;
      }
      try {
        const { data } = parseOrRepair(raw);
        renderTree(data);
        input.classList.remove('error-line');
      } catch (e) {
        input.classList.add('error-line');
        showMsg(`自动预览失败：${(e as Error).message}`, 'error');
      }
    }, 1000);
  }

  function normalizePath(pathRaw: string) {
    return pathRaw.replace(/\.\d+\./g, '.*.').replace(/\.\d+$/g, '.*');
  }

  function pathMatches(path: string, pattern: string) {
    if (pattern.startsWith('*.')) {
      const tail = pattern.slice(1);
      return path.endsWith(tail);
    }
    const norm = normalizePath(path);
    const p1 = norm.split('.');
    const p2 = pattern.split('.');
    if (p1.length != p2.length) return false;
    for (let i = 0; i < p1.length; i += 1) {
      if (p2[i] == '*') continue;
      if (p1[i] != p2[i]) return false;
    }
    return true;
  }

  function setRowOpen(row: Element, shouldOpen: boolean) {
    const opened = row.classList.contains('json-formatter-open');
    if (opened == shouldOpen) return false;
    const toggler = row.querySelector(':scope > .json-formatter-toggler-link');
    if (toggler instanceof HTMLElement) {
      toggler.click();
      return true;
    }
    return false;
  }

  function applyPathRules() {
    for (let turn = 0; turn < 8; turn += 1) {
      let changed = false;
      const rows = output.querySelectorAll('.json-formatter-row[data-path]');
      rows.forEach((row) => {
        const path = row.getAttribute('data-path');
        if (!path) return;
        const parsed = JSON.parse(path);
        const keyPath = Array.isArray(parsed) ? parsed.join('.') : '';
        if (!keyPath) return;
        if (pathConfig.expandPaths.some((p) => pathMatches(keyPath, p))) {
          if (setRowOpen(row, true)) changed = true;
        }
      });
      if (!changed) break;
    }
    const rows = output.querySelectorAll('.json-formatter-row[data-path]');
    rows.forEach((row) => {
      const path = row.getAttribute('data-path');
      if (!path) return;
      const parsed = JSON.parse(path);
      const keyPath = Array.isArray(parsed) ? parsed.join('.') : '';
      if (!keyPath) return;
      if (pathConfig.collapsePaths.some((p) => pathMatches(keyPath, p))) {
        setRowOpen(row, false);
      }
    });
  }

  function applyOutputStyle() {
    output.classList.remove('json-style-bracket', 'json-style-guide', 'json-style-plain', 'json-style-code');
    output.classList.add(`json-style-${currentStyle}`);
    styleSwitch.querySelectorAll('button').forEach((btn) => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.style == currentStyle);
    });
  }

  function togglePageFull() {
    workbench.classList.toggle('is-json-page-full');
    document.body.classList.toggle('json-page-full', workbench.classList.contains('is-json-page-full'));
    fullBtn.textContent = workbench.classList.contains('is-json-page-full') ? '退出全屏' : '页面全屏';
  }

  input.addEventListener('input', () => {
    updateStats(input.value, inputStats);
    scheduleAutoPreview();
  });

  document.getElementById('btn-format')!.addEventListener('click', () => runFormat(true));
  document.getElementById('btn-minify')!.addEventListener('click', () => runFormat(false));

  document.getElementById('btn-validate')!.addEventListener('click', () => {
    const raw = input.value.trim();
    if (!raw) { showMsg('请输入 JSON 内容', 'error'); return; }
    try {
      parseOrRepair(raw);
      input.classList.remove('error-line');
      showMsg('✓ JSON 语法正确', 'success');
    } catch (e) {
      input.classList.add('error-line');
      showMsg((e as Error).message, 'error');
    }
  });

  toggleBtn.addEventListener('click', () => {
    if (lastData == null) return;
    treeExpanded = !treeExpanded;
    renderTree(lastData);
  });

  fullBtn.addEventListener('click', () => togglePageFull());

  styleSwitch.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button');
    if (!btn) return;
    currentStyle = (btn as HTMLElement).dataset.style as 'bracket' | 'guide' | 'plain' | 'code';
    applyOutputStyle();
  });

  document.getElementById('btn-clear')!.addEventListener('click', () => {
    input.value = '';
    treeExpanded = false;
    renderEmpty();
    msg.textContent = '';
    msg.className = '';
    input.classList.remove('error-line');
    updateStats('', inputStats);
    toggleBtn.textContent = '全部展开';
  });
</script>

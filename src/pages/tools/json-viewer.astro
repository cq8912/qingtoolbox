---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout title="JSON 在线查看器" description="JSON 格式化校验工具：在线修复、压缩、树形查看，支持大文本，浏览器本地处理。" currentSlug="json-viewer">
  <h1 slot="header">JSON 在线查看器</h1>
  <p class="intro">粘贴 JSON，格式化失败时自动尝试修复，输出为可折叠树形视图。</p>

  <div class="json-workbench" id="json-workbench">
    <div class="json-split">
      <div class="tool-panel json-pane">
        <label for="json-input">输入</label>
        <div class="json-pane-body">
          <textarea id="json-input" class="json-editor" placeholder='{"name": "示例"}'></textarea>
        </div>
        <div class="json-pane-foot">
          <p class="field-hint" id="json-input-stats">0 字符 · 0 行</p>
          <div class="btn-row">
            <button class="btn" id="btn-format">格式化</button>
            <button class="btn btn-secondary" id="btn-minify">压缩</button>
            <button class="btn btn-secondary" id="btn-validate">校验</button>
            <button class="btn btn-secondary" id="btn-clear">清空</button>
          </div>
          <div id="json-msg"></div>
          <div class="json-expand-rules">
            <label for="path-expand-rules">展开路径（每行一条，支持后缀：function、tools.*.function）</label>
            <textarea id="path-expand-rules" rows="2" spellcheck="false" placeholder="tools.*.function"></textarea>
          </div>
          <div class="json-expand-rules">
            <div class="json-rule-head">
              <label for="field-filter-rules">字段筛选（每行一条，只保留键名匹配字段，如 stream、thinkProcess）</label>
              <button type="button" class="btn btn-secondary btn-sm" id="btn-clear-field-filter">清空字段筛选</button>
            </div>
            <textarea id="field-filter-rules" rows="2" spellcheck="false" placeholder="stream&#10;thinkProcess"></textarea>
          </div>
        </div>
      </div>
      <div class="tool-panel json-pane">
        <div class="json-panel-header">
          <label>输出</label>
          <div class="json-header-actions">
            <button type="button" class="btn btn-secondary btn-sm" id="btn-copy-output">复制输出</button>
            <button type="button" class="btn btn-secondary btn-sm" id="btn-toggle-tree">全部展开</button>
            <button type="button" class="btn btn-secondary btn-sm" id="btn-json-full">页面全屏</button>
          </div>
        </div>
        <div class="json-pane-body">
          <div class="json-output-wrap" id="json-output">
            <span class="json-placeholder" id="json-placeholder">结果将显示在这里</span>
            <div id="json-editor-host" hidden></div>
          </div>
        </div>
        <div class="json-pane-foot">
          <p class="field-hint" id="json-output-stats">0 字符 · 0 行</p>
        </div>
      </div>
    </div>
  </div>
</ToolLayout>

<script>
  import { jsonrepair } from 'jsonrepair';
  import { createJSONEditor, Mode, expandAll, expandNone } from 'vanilla-jsoneditor';

  type JsonPath = Array<string | number>;

  const PATH_KEY = 'json-viewer-expand-paths';
  const FILTER_KEY = 'json-viewer-field-filters';

  const input = document.getElementById('json-input') as HTMLTextAreaElement;
  const placeholder = document.getElementById('json-placeholder')!;
  const editorHost = document.getElementById('json-editor-host') as HTMLDivElement;
  const msg = document.getElementById('json-msg')!;
  const inputStats = document.getElementById('json-input-stats')!;
  const outputStats = document.getElementById('json-output-stats')!;
  const toggleBtn = document.getElementById('btn-toggle-tree')!;
  const fullBtn = document.getElementById('btn-json-full')!;
  const workbench = document.getElementById('json-workbench')!;
  const expandRulesEl = document.getElementById('path-expand-rules') as HTMLTextAreaElement;
  const fieldFilterEl = document.getElementById('field-filter-rules') as HTMLTextAreaElement;

  let rawData: any = null;
  let lastData: any = null;
  let treeExpanded = false;
  let forceManualCollapse = false;
  let previewTimer: number | null = null;
  let pathTimer: number | null = null;
  let filterTimer: number | null = null;
  let editor: ReturnType<typeof createJSONEditor> | null = null;

  let pathConfig = { expandPaths: [] as string[] };
  let fieldConfig = { includeKeys: [] as string[] };

  function ensureEditor() {
    if (editor) return editor;
    editor = createJSONEditor({
      target: editorHost,
      props: {
        mode: Mode.tree,
        readOnly: true,
        mainMenuBar: false,
        navigationBar: false,
        statusBar: false,
        content: { json: {} },
      },
    });
    return editor;
  }

  function showTreeView() {
    placeholder.hidden = true;
    editorHost.hidden = false;
  }

  function showPlaceholder() {
    placeholder.hidden = false;
    editorHost.hidden = true;
  }

  function loadPathRules() {
    try {
      const raw = localStorage.getItem(PATH_KEY);
      if (raw) {
        const saved = JSON.parse(raw);
        if (Array.isArray(saved.expandPaths)) pathConfig.expandPaths = saved.expandPaths;
      }
    } catch {}
    expandRulesEl.value = pathConfig.expandPaths.join('\n');
  }

  function loadFieldRules() {
    try {
      const raw = localStorage.getItem(FILTER_KEY);
      if (raw) {
        const saved = JSON.parse(raw);
        if (Array.isArray(saved.includeKeys)) fieldConfig.includeKeys = saved.includeKeys;
      }
    } catch {}
    fieldFilterEl.value = fieldConfig.includeKeys.join('\n');
  }

  function syncPathRulesFromInput() {
    pathConfig.expandPaths = expandRulesEl.value.split('\n').map((s) => s.trim()).filter(Boolean);
    localStorage.setItem(PATH_KEY, JSON.stringify(pathConfig));
  }

  function syncFieldRulesFromInput() {
    fieldConfig.includeKeys = [...new Set(fieldFilterEl.value.split('\n').map((s) => s.trim()).filter(Boolean))];
    localStorage.setItem(FILTER_KEY, JSON.stringify(fieldConfig));
  }

  function showMsg(text: string, type: 'error' | 'success') {
    msg.className = `msg ${type}`;
    msg.textContent = text;
  }

  function updateStats(text: string, statsEl: HTMLElement) {
    statsEl.textContent = `${text.length} 字符 · ${text ? text.split('\n').length : 0} 行`;
  }

  function getErrorLine(raw: string, err: Error) {
    const m = err.message.match(/position\s+(\d+)/i);
    if (!m) return null;
    return raw.slice(0, Number(m[1])).split('\n').length;
  }

  function normalizePath(pathRaw: string) {
    return pathRaw.replace(/\.\d+\./g, '.*.').replace(/\.\d+$/g, '.*');
  }

  function pathToKey(path: JsonPath) {
    return path.map(String).join('.');
  }

  function pathMatchesExpand(path: string, pattern: string) {
    const norm = normalizePath(path);
    const pat = pattern.trim();
    if (!pat) return false;

    if (!pat.includes('.')) {
      const segs = norm.split('.');
      return segs[segs.length - 1] == pat;
    }

    const p2 = pat.split('.');
    const p1 = norm.split('.');
    if (p1.length < p2.length) return false;

    const off = p1.length - p2.length;
    for (let i = 0; i < p2.length; i += 1) {
      if (p2[i] == '*') continue;
      if (p1[off + i] != p2[i]) return false;
    }
    return true;
  }

  function pathKeyToJsonPath(key: string): JsonPath {
    return key.split('.').map((seg) => (/^\d+$/.test(seg) ? Number(seg) : seg));
  }

  function isPlainObject(value: unknown) {
    return value != null && typeof value == 'object' && !Array.isArray(value);
  }

  function filterDataByKeys(data: unknown, keys: Set<string>): unknown {
    if (!keys.size) return data;

    // 忽略大小写匹配键名
    const keysLower = new Set([...keys].map((k) => k.toLowerCase()));
    const keyHit = (key: string) => keysLower.has(key.toLowerCase());

    if (Array.isArray(data)) {
      const next = data.map((item) => filterDataByKeys(item, keys)).filter((item) => item !== undefined);
      return next.length ? next : undefined;
    }

    if (!isPlainObject(data)) return undefined;

    const next: Record<string, unknown> = {};
    Object.entries(data as Record<string, unknown>).forEach(([key, value]) => {
      if (keyHit(key)) {
        next[key] = value;
        return;
      }
      const child = filterDataByKeys(value, keys);
      if (child !== undefined) next[key] = child;
    });

    return Object.keys(next).length ? next : undefined;
  }

  function getViewData(data: unknown) {
    if (!fieldConfig.includeKeys.length) return data;
    const filtered = filterDataByKeys(data, new Set(fieldConfig.includeKeys));
    if (filtered !== undefined) return filtered;
    if (Array.isArray(data)) return [];
    if (isPlainObject(data)) return {};
    return data;
  }

  function forceCollapseAll() {
    if (!editor || lastData == null) return;
    editor.expand([], expandNone);
    const paths = collectPaths(lastData).sort((a, b) => b.length - a.length);
    paths.forEach((path) => {
      editor!.collapse(path.map((p) => String(p)), true);
    });
  }

  function applyPathRules() {
    if (!editor || lastData == null || !pathConfig.expandPaths.length) return;
    const paths = collectPaths(lastData);
    const matched: JsonPath[] = [];

    paths.forEach((path) => {
      const keyPath = pathToKey(path);
      if (pathConfig.expandPaths.some((p) => pathMatchesExpand(keyPath, p))) {
        matched.push(path);
      }
    });

    if (!matched.length) return;

    const matchedKeys = new Set(matched.map(pathToKey));
    forceCollapseAll();

    const expandKeys = new Set<string>();
    matched.forEach((path) => {
      for (let i = 1; i <= path.length; i += 1) {
        expandKeys.add(pathToKey(path.slice(0, i)));
      }
    });

    [...expandKeys]
      .map(pathKeyToJsonPath)
      .sort((a, b) => a.length - b.length)
      .forEach((path) => {
        editor!.expand(path.map((p) => String(p)));
      });

    paths
      .sort((a, b) => b.length - a.length)
      .forEach((path) => {
        const keyPath = pathToKey(path);
        for (const mk of matchedKeys) {
          if (isDescendantKey(keyPath, mk)) {
            editor!.collapse(path.map((p) => String(p)), true);
            break;
          }
        }
      });
  }

  function runExpandState() {
    if (!editor || lastData == null) return;
    if (treeExpanded) {
      editor.expand([], expandAll);
      toggleBtn.textContent = '全部折叠';
      return;
    }
    if (forceManualCollapse) {
      forceCollapseAll();
      toggleBtn.textContent = '全部展开';
      return;
    }
    if (fieldConfig.includeKeys.length) {
      editor.expand([], expandAll);
      toggleBtn.textContent = '全部折叠';
      return;
    }
    if (pathConfig.expandPaths.length) {
      forceCollapseAll();
      applyPathRules();
    } else {
      forceCollapseAll();
    }
    toggleBtn.textContent = '全部展开';
  }

  function applyTreeExpandState() {
    if (!editor || lastData == null) return;
    // 深拷贝，避免编辑器复用旧树结构导致清空筛选后不刷新
    const view = JSON.parse(JSON.stringify(lastData));
    editor.set({ json: view });
    editor.refresh();
    requestAnimationFrame(() => runExpandState());
  }

  function renderView() {
    if (rawData == null) {
      renderEmpty();
      return;
    }
    lastData = getViewData(rawData);
    forceManualCollapse = false;
    showTreeView();
    ensureEditor();
    applyTreeExpandState();
    updateStats(JSON.stringify(lastData, null, 2), outputStats);
  }

  function collectPaths(data: unknown, prefix: JsonPath = []): JsonPath[] {
    const paths: JsonPath[] = [];
    if (prefix.length) paths.push(prefix);
    if (Array.isArray(data)) {
      data.forEach((item, i) => {
        paths.push(...collectPaths(item, [...prefix, i]));
      });
    } else if (data != null && typeof data == 'object') {
      Object.keys(data as object).forEach((key) => {
        paths.push(...collectPaths((data as Record<string, unknown>)[key], [...prefix, key]));
      });
    }
    return paths;
  }

  function isDescendantKey(keyPath: string, ancestor: string) {
    return keyPath != ancestor && keyPath.startsWith(ancestor + '.');
  }

  function schedulePathApply() {
    if (pathTimer) window.clearTimeout(pathTimer);
    pathTimer = window.setTimeout(() => {
      syncPathRulesFromInput();
      if (lastData == null || treeExpanded || !editor || fieldConfig.includeKeys.length) return;
      forceManualCollapse = false;
      runExpandState();
    }, 400);
  }

  function applyFieldFilters() {
    if (filterTimer) window.clearTimeout(filterTimer);
    filterTimer = window.setTimeout(() => {
      syncFieldRulesFromInput();
      if (rawData == null) return;
      treeExpanded = false;
      forceManualCollapse = false;
      renderView();
    }, 250);
  }

  function renderTree(data: any) {
    rawData = data;
    renderView();
  }

  function renderEmpty() {
    rawData = null;
    lastData = null;
    showPlaceholder();
    updateStats('', outputStats);
  }

  function parseOrRepair(raw: string) {
    try {
      return { data: JSON.parse(raw), repaired: false };
    } catch (e) {
      const err = e as Error;
      const line = getErrorLine(raw, err);
      const errDesc = line ? `第 ${line} 行附近：${err.message}` : err.message;
      try {
        return { data: JSON.parse(jsonrepair(raw)), repaired: true, errDesc };
      } catch {
        throw new Error(errDesc + ' → 自动修复失败，请人工检查');
      }
    }
  }

  function runFormat() {
    const raw = input.value.trim();
    if (!raw) {
      showMsg('请输入 JSON 内容', 'error');
      return;
    }
    try {
      const { data, repaired, errDesc } = parseOrRepair(raw);
      input.value = JSON.stringify(data, null, 2);
      updateStats(input.value, inputStats);
      renderTree(data);
      input.classList.remove('error-line');
      if (repaired && errDesc) showMsg(`${errDesc} → 已自动修复`, 'success');
      else showMsg('格式化成功', 'success');
    } catch (e) {
      input.classList.add('error-line');
      showMsg((e as Error).message, 'error');
      renderEmpty();
    }
  }

  function runMinify() {
    const raw = input.value.trim();
    if (!raw) {
      showMsg('请输入 JSON 内容', 'error');
      return;
    }
    try {
      const { data, repaired, errDesc } = parseOrRepair(raw);
      input.value = JSON.stringify(data);
      updateStats(input.value, inputStats);
      renderTree(data);
      input.classList.remove('error-line');
      if (repaired && errDesc) showMsg(`${errDesc} → 已自动修复并压缩`, 'success');
      else showMsg('压缩成功（已写入输入框）', 'success');
    } catch (e) {
      input.classList.add('error-line');
      showMsg((e as Error).message, 'error');
      renderEmpty();
    }
  }

  function scheduleAutoPreview() {
    if (previewTimer) window.clearTimeout(previewTimer);
    previewTimer = window.setTimeout(() => {
      const raw = input.value.trim();
      if (!raw) {
        renderEmpty();
        msg.textContent = '';
        msg.className = '';
        return;
      }
      try {
        const { data } = parseOrRepair(raw);
        renderTree(data);
        input.classList.remove('error-line');
      } catch (e) {
        input.classList.add('error-line');
        showMsg(`自动预览失败：${(e as Error).message}`, 'error');
      }
    }, 1000);
  }

  function togglePageFull() {
    workbench.classList.toggle('is-json-page-full');
    document.body.classList.toggle('json-page-full', workbench.classList.contains('is-json-page-full'));
    fullBtn.textContent = workbench.classList.contains('is-json-page-full') ? '退出全屏' : '页面全屏';
    if (editor) window.setTimeout(() => editor!.refresh(), 80);
  }

  loadPathRules();
  loadFieldRules();

  input.addEventListener('input', () => {
    updateStats(input.value, inputStats);
    scheduleAutoPreview();
  });

  expandRulesEl.addEventListener('input', schedulePathApply);
  fieldFilterEl.addEventListener('input', applyFieldFilters);

  document.getElementById('btn-format')!.addEventListener('click', runFormat);
  document.getElementById('btn-minify')!.addEventListener('click', runMinify);

  document.getElementById('btn-validate')!.addEventListener('click', () => {
    const raw = input.value.trim();
    if (!raw) { showMsg('请输入 JSON 内容', 'error'); return; }
    try {
      parseOrRepair(raw);
      input.classList.remove('error-line');
      showMsg('✓ JSON 语法正确', 'success');
    } catch (e) {
      input.classList.add('error-line');
      showMsg((e as Error).message, 'error');
    }
  });

  document.getElementById('btn-copy-output')!.addEventListener('click', async () => {
    if (lastData == null) {
      showMsg('当前没有可复制的输出内容', 'error');
      return;
    }
    await navigator.clipboard.writeText(JSON.stringify(lastData, null, 2));
    showMsg('已复制当前输出 JSON', 'success');
  });

  document.getElementById('btn-clear-field-filter')!.addEventListener('click', () => {
    if (filterTimer) window.clearTimeout(filterTimer);
    fieldFilterEl.value = '';
    fieldConfig.includeKeys = [];
    localStorage.setItem(FILTER_KEY, JSON.stringify(fieldConfig));
    if (rawData == null) return;
    treeExpanded = false;
    forceManualCollapse = false;
    renderView();
    showMsg('已清空字段筛选', 'success');
  });

  toggleBtn.addEventListener('click', () => {
    if (lastData == null) return;
    if (fieldConfig.includeKeys.length) {
      forceManualCollapse = !forceManualCollapse;
      treeExpanded = false;
      runExpandState();
      return;
    }
    if (treeExpanded) {
      treeExpanded = false;
      forceManualCollapse = true;
    } else {
      treeExpanded = true;
      forceManualCollapse = false;
    }
    runExpandState();
  });

  fullBtn.addEventListener('click', () => togglePageFull());

  document.getElementById('btn-clear')!.addEventListener('click', () => {
    input.value = '';
    treeExpanded = false;
    forceManualCollapse = false;
    renderEmpty();
    msg.textContent = '';
    msg.className = '';
    input.classList.remove('error-line');
    updateStats('', inputStats);
    toggleBtn.textContent = '全部展开';
  });
</script>

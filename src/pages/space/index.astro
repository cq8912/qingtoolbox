---
import { BODIES } from '../../scripts/space/constants';
import { SPEED_PRESETS, TIME_PRESETS } from '../../scripts/space/constants';
import { DEST_STARS } from '../../scripts/space/starCatalog';

const TEX: Record<string, string> = {
  sun: '/space/textures/2k_sun.jpg',
  mercury: '/space/textures/2k_mercury.jpg',
  venus: '/space/textures/2k_venus_surface.jpg',
  earth: '/space/textures/2k_earth_daymap.jpg',
  moon: '/space/textures/2k_moon.jpg',
  mars: '/space/textures/2k_mars.jpg',
  jupiter: '/space/textures/2k_jupiter.jpg',
  saturn: '/space/textures/2k_saturn.jpg',
  uranus: '/space/textures/2k_uranus.jpg',
  neptune: '/space/textures/2k_neptune.jpg',
};

function hexColor(n: number) {
  return '#' + n.toString(16).padStart(6, '0');
}

const PRIMARY = BODIES.filter((b) => !b.moonOf);
const moonsOf = (id: string) => BODIES.filter((b) => b.moonOf == id);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="description" content="三维太阳系模拟星图" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Oxanium:wght@500;700&display=swap" rel="stylesheet" />
    <title>轻星图 · 太阳系模拟 | 轻工具箱</title>
    <style>
      :root {
        --void: #030508;
        --cyan: #00e8ff;
        --cyan-dim: rgba(0, 232, 255, 0.35);
        --cyan-glow: rgba(0, 232, 255, 0.55);
        --amber: #ffc857;
        --panel: rgba(4, 10, 18, 0.82);
        --line: rgba(0, 232, 255, 0.18);
        --text: #e8f4ff;
        --font-d: 'Oxanium', sans-serif;
        --font-m: 'IBM Plex Mono', monospace;
        --drawer-tab: 30px;
        --ease: cubic-bezier(0.22, 1, 0.36, 1);
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0; height: 100%; overflow: hidden;
        background: var(--void); color: var(--text);
        font-family: var(--font-d);
        overscroll-behavior: none;
      }

      /* 扫描线叠层 */
      body::after {
        content: '';
        position: fixed; inset: 0; z-index: 5;
        pointer-events: none;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(0, 232, 255, 0.015) 2px,
          rgba(0, 232, 255, 0.015) 4px
        );
        opacity: 0.6;
      }

      #space-canvas {
        position: fixed; inset: 0; z-index: 1;
        width: 100%; height: 100%; display: block;
        touch-action: none; cursor: crosshair;
        overscroll-behavior: none;
      }
      #space-canvas:active { cursor: grabbing; }

      #space-hud {
        position: fixed; inset: 0; z-index: 10;
        pointer-events: none;
      }
      #space-hud button,
      #space-hud a,
      #space-hud select,
      #space-hud input,
      #space-hud label,
      #space-hud .sp-drawer,
      #space-hud .sp-minimap-wrap,
      #space-hud .sp-moon-chip,
      #space-hud .sp-star-pick {
        pointer-events: auto;
        cursor: pointer;
      }

      /* 科幻角标 */
      .sp-corners {
        position: relative;
      }
      .sp-corners::before,
      .sp-corners::after {
        content: '';
        position: absolute;
        width: 12px; height: 12px;
        border-color: var(--cyan);
        border-style: solid;
        pointer-events: none;
        opacity: 0.7;
      }
      .sp-corners::before {
        top: -1px; left: -1px;
        border-width: 2px 0 0 2px;
      }
      .sp-corners::after {
        bottom: -1px; right: -1px;
        border-width: 0 2px 2px 0;
      }

      .sp-muted {
        opacity: 0.35;
        filter: blur(0.6px);
        transition: opacity 0.35s var(--ease), filter 0.35s var(--ease);
      }
      .sp-drawer:hover .sp-muted,
      .sp-drawer:focus-within .sp-muted,
      .sp-top:hover .sp-muted,
      .sp-top:focus-within .sp-muted,
      .sp-minimap-wrap:hover .sp-muted,
      .sp-pick:hover .sp-muted,
      .sp-pick.is-on .sp-muted,
      .sp-btn.is-on,
      .sp-readout {
        opacity: 0.95;
        filter: blur(0);
      }

      .sp-zone {
        background: var(--panel);
        border: 1px solid var(--line);
        backdrop-filter: blur(16px) saturate(1.4);
        box-shadow: 0 0 24px rgba(0, 232, 255, 0.06), inset 0 1px 0 rgba(255,255,255,0.04);
      }

      /* 底部外壳不画框，避免与内容区叠线 */
      .sp-drawer-bottom.sp-zone {
        background: transparent;
        border: none;
        box-shadow: none;
        backdrop-filter: none;
      }
      .sp-drawer-bottom .sp-drawer-body.sp-dock {
        background: var(--panel);
        border: 1px solid var(--line);
        border-top: none;
        border-radius: 0;
        backdrop-filter: blur(16px) saturate(1.4);
        box-shadow: 0 0 24px rgba(0, 232, 255, 0.06);
      }
      .sp-drawer-bottom .sp-drawer-tab {
        border: 1px solid var(--line);
        border-bottom: none;
        background: var(--panel);
      }

      /* 顶栏 HUD */
      .sp-top {
        position: absolute;
        top: 0; left: 0; right: 0;
        display: flex; align-items: center; justify-content: space-between;
        padding: 10px 16px;
        background: linear-gradient(180deg, rgba(0, 8, 16, 0.75), transparent);
        border: 0; border-bottom: 1px solid var(--line);
      }
      .sp-title {
        font-size: 0.92rem; letter-spacing: 0.22em; font-weight: 700;
        color: var(--cyan);
        text-shadow: 0 0 12px var(--cyan-glow);
      }
      .sp-title::before { content: '◈ '; opacity: 0.6; }
      .sp-meta {
        font-family: var(--font-m); font-size: 0.65rem;
        flex: 1; text-align: center; letter-spacing: 0.06em;
        color: var(--cyan-dim);
      }
      .sp-top-btns { display: flex; gap: 6px; }
      .sp-btn {
        border: 1px solid var(--line);
        background: rgba(0, 232, 255, 0.04);
        color: var(--text);
        font: inherit; font-size: 0.74rem; letter-spacing: 0.08em;
        padding: 6px 12px; text-decoration: none;
        transition: border-color 0.2s, box-shadow 0.2s, color 0.2s;
      }
      .sp-btn:hover {
        border-color: var(--cyan-dim);
        box-shadow: 0 0 12px rgba(0, 232, 255, 0.15);
        color: var(--cyan);
      }
      .sp-btn.is-on {
        background: rgba(0, 232, 255, 0.12);
        color: var(--cyan);
        border-color: var(--cyan-glow);
        box-shadow: 0 0 16px rgba(0, 232, 255, 0.2);
      }

      /* 左侧抽屉：默认展开，点标签折叠 */
      .sp-drawer-left {
        position: absolute;
        left: 0; top: 50%;
        transform: translateY(-50%) translateX(0);
        transition: transform 0.4s var(--ease);
        display: flex; align-items: stretch;
        z-index: 12;
      }
      .sp-drawer-left.is-collapsed {
        transform: translateY(-50%) translateX(calc(-100% + var(--drawer-tab)));
      }
      .sp-drawer-tab {
        width: var(--drawer-tab);
        flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        writing-mode: vertical-rl;
        font-family: var(--font-m); font-size: 0.58rem;
        letter-spacing: 0.2em;
        color: var(--cyan);
        background: var(--panel);
        border: 1px solid var(--line);
        border-left: none;
        text-shadow: 0 0 8px var(--cyan-glow);
        cursor: pointer;
        user-select: none;
        padding: 0;
        margin: 0;
        appearance: none;
        -webkit-appearance: none;
      }
      .sp-drawer-left.sp-zone {
        overflow: hidden; /* 选中框不得撑破外框 */
      }
      .sp-drawer-left .sp-drawer-body {
        padding: 8px;
        width: 148px;
        min-width: 0;
        box-sizing: border-box;
        overflow: hidden;
      }
      .sp-drawer-body {
        padding: 8px;
        min-width: 0;
      }
      .sp-rail {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 4px;
        width: 100%;
        border: none; background: transparent;
        box-shadow: none;
        max-height: none;
        overflow: hidden;
      }
      .sp-rail-split {
        display: flex;
        flex-direction: column;
        gap: 6px;
        width: 100%;
        min-width: 0;
        max-height: none;
        overflow: hidden;
        padding: 0;
        box-sizing: border-box;
      }
      .sp-rail-modes {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 4px;
      }
      .sp-rail-modes button {
        border: 1px solid var(--line);
        background: rgba(0, 232, 255, 0.04);
        color: var(--text);
        font: inherit;
        font-size: 0.62rem;
        letter-spacing: 0.08em;
        padding: 5px 4px;
        font-family: var(--font-m);
        min-width: 0;
      }
      .sp-rail-modes button.is-on {
        color: var(--cyan);
        border-color: var(--cyan-glow);
        background: rgba(0, 232, 255, 0.12);
      }
      #sp-rail-stars {
        display: none;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 4px;
        max-height: 62vh;
        overflow-x: hidden;
        overflow-y: auto;
        width: 100%;
      }
      /* 左侧切换：天体 / 星域（与跨尺度无关，点星才跃迁） */
      #space-hud[data-rail='stars'] #sp-rail { display: none; }
      #space-hud[data-rail='stars'] #sp-rail-stars { display: grid; }
      #space-hud[data-rail='bodies'] #sp-rail { display: grid; }
      #space-hud[data-rail='bodies'] #sp-rail-stars { display: none; }
      .sp-pick {
        display: flex; flex-direction: column; align-items: center; gap: 2px;
        border: 0; background: transparent;
        padding: 2px; color: inherit; font: inherit;
        border-radius: 0;
        width: 100%;
        min-width: 0;
        box-shadow: none;
      }
      .sp-pick:hover .sp-thumb,
      .sp-pick:hover .sp-thumb-swatch,
      .sp-pick.is-on .sp-thumb,
      .sp-pick.is-on .sp-thumb-swatch {
        box-shadow: 0 0 0 1px var(--cyan), inset -2px -2px 6px rgba(0,0,0,0.55);
      }
      .sp-thumb {
        width: 30px; height: 30px; border-radius: 50%;
        object-fit: cover;
        box-shadow: inset -2px -2px 6px rgba(0,0,0,0.55), 0 0 0 1px rgba(0,232,255,0.15);
        display: block;
        flex-shrink: 0;
      }
      .sp-thumb-swatch {
        width: 30px; height: 30px; border-radius: 50%;
        box-shadow: inset -2px -2px 6px rgba(0,0,0,0.5), 0 0 0 1px rgba(0,232,255,0.2);
        display: block;
        flex-shrink: 0;
      }
      .sp-pick span.sp-name {
        font-size: 0.55rem; letter-spacing: 0.04em; font-family: var(--font-m);
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      /* 主星+卫星同一框；选中框不得超出格子 */
      .sp-cell {
        display: flex; flex-direction: column; align-items: center; gap: 2px;
        width: 100%;
        min-width: 0;
        max-width: 100%;
        box-sizing: border-box;
        padding: 3px 2px 4px;
        border: 1px solid transparent;
        border-radius: 6px;
        overflow: hidden;
        background: transparent;
        transition: border-color 0.2s, background 0.2s;
      }
      .sp-cell.is-hot {
        border-color: var(--cyan-dim);
        background: rgba(0, 232, 255, 0.06);
      }
      .sp-moon-pack {
        display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
        gap: 2px;
        max-width: 100%;
        padding: 0;
        border: none;
        background: transparent;
      }
      .sp-cell.is-hot .sp-moon-pack { filter: brightness(1.15); }
      .sp-rail-label {
        display: none;
      }
      .sp-star-pick {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
        border: 1px solid transparent;
        background: transparent;
        padding: 4px 2px;
        color: inherit;
        font: inherit;
        font-size: 0.58rem;
        border-radius: 4px;
        width: 100%;
      }
      .sp-star-pick:hover, .sp-star-pick.is-on {
        border-color: rgba(255, 200, 87, 0.45);
        background: rgba(255, 200, 87, 0.06);
      }
      .sp-star-dot {
        width: 12px; height: 12px;
        border-radius: 50%;
        box-shadow: 0 0 8px currentColor;
        display: block;
      }
      .sp-star-pick.is-on .sp-star-dot {
        outline: 1px solid var(--cyan);
        outline-offset: 2px;
      }
      .sp-moon-chip {
        width: 14px; height: 14px; padding: 0; border: 1px solid transparent;
        border-radius: 50%; background: transparent;
        display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer;
        transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
      }
      .sp-moon-chip:hover, .sp-moon-chip.is-on {
        border-color: var(--cyan-dim);
        box-shadow: 0 0 8px rgba(0, 232, 255, 0.25);
        transform: scale(1.15);
      }
      .sp-moon-dot {
        width: 9px; height: 9px; border-radius: 50%;
        box-shadow: inset -1px -1px 3px rgba(0,0,0,0.55);
        display: block;
      }
      .sp-moon-chip.is-on .sp-moon-dot {
        box-shadow: 0 0 0 1px var(--cyan), inset -1px -1px 3px rgba(0,0,0,0.45);
      }

      /* 场景旁名称（fixed，由 labels.ts 写 left/top） */
      #sp-labels {
        position: fixed; inset: 0;
        pointer-events: none; z-index: 9;
      }
      .sp-label {
        position: fixed;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1px;
        font-family: var(--font-m);
        letter-spacing: 0.14em;
        color: rgba(180, 230, 255, 0.42);
        text-shadow: 0 1px 6px rgba(0,0,0,0.75);
        transform: translate(-50%, -120%);
        white-space: nowrap;
        transition: color 0.25s, opacity 0.25s;
        opacity: 0.75;
        pointer-events: auto;
        cursor: pointer;
        padding: 2px 4px;
      }
      .sp-label:hover {
        color: rgba(0, 232, 255, 0.9);
        opacity: 1;
      }
      .sp-label-name {
        font-size: 0.62rem;
      }
      .sp-label-dist {
        font-size: 0.5rem;
        letter-spacing: 0.08em;
        opacity: 0.75;
      }
      .sp-label.is-focus {
        color: rgba(0, 232, 255, 0.88);
        opacity: 0.98;
      }
      .sp-label.is-focus .sp-label-name {
        letter-spacing: 0.2em;
      }
      .sp-label.is-dim {
        opacity: 0.55;
      }
      .sp-label.is-dim .sp-label-name {
        font-size: 0.55rem;
        letter-spacing: 0.1em;
      }

      /* 底部抽屉：默认展开，点标签折叠 */
      .sp-drawer-bottom {
        position: absolute;
        left: 50%; bottom: 0;
        transform: translateX(-50%) translateY(0);
        transition: transform 0.4s var(--ease);
        display: flex; flex-direction: column; align-items: center;
        z-index: 12;
        max-width: calc(100vw - 24px);
      }
      .sp-drawer-bottom.is-collapsed {
        transform: translateX(-50%) translateY(calc(100% - var(--drawer-tab)));
      }
      .sp-drawer-bottom .sp-drawer-tab {
        writing-mode: horizontal-tb;
        width: auto; min-width: 120px;
        height: var(--drawer-tab);
        border-bottom: none;
        border-top: 1px solid var(--line);
        letter-spacing: 0.14em;
        cursor: pointer;
        user-select: none;
      }

      /* 太阳系下顶栏弹出的邻近恒星面板 */
      .sp-star-panel {
        display: none;
        position: absolute;
        top: 52px; left: 50%;
        transform: translateX(-50%);
        z-index: 14;
        width: min(420px, calc(100vw - 24px));
        max-height: 50vh;
        overflow-y: auto;
        padding: 10px 12px;
      }
      .sp-star-panel.is-open { display: block; }
      .sp-star-panel-title {
        font-family: var(--font-m);
        font-size: 0.62rem;
        letter-spacing: 0.14em;
        color: var(--amber);
        margin-bottom: 8px;
      }
      .sp-star-panel-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 6px;
      }
      .sp-dock {
        display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
        gap: 8px; padding: 10px 14px;
        border: none; background: transparent; box-shadow: none;
      }
      .sp-seg { display: flex; border: 1px solid var(--line); }
      .sp-seg button {
        border: 0; background: transparent; color: inherit;
        font: inherit; font-size: 0.72rem; letter-spacing: 0.06em;
        padding: 6px 12px;
        transition: background 0.2s, color 0.2s;
      }
      .sp-seg button.is-on {
        background: rgba(0, 232, 255, 0.14);
        color: var(--cyan);
        text-shadow: 0 0 8px var(--cyan-glow);
      }
      .sp-field {
        display: flex; align-items: center; gap: 5px;
        font-size: 0.66rem; font-family: var(--font-m);
      }
      .sp-field select, .sp-field input[type='datetime-local'] {
        border: 1px solid var(--line);
        background: rgba(0, 8, 16, 0.6); color: var(--text);
        font-family: var(--font-m); font-size: 0.62rem;
        padding: 4px 5px; max-width: 130px;
      }
      .sp-field input[type='checkbox'] { accent-color: var(--cyan); }

      /* 战术星图 */
      .sp-minimap-wrap {
        position: absolute;
        top: 52px; right: 10px;
        width: 168px;
        z-index: 11;
      }
      .sp-minimap-label {
        font-family: var(--font-m); font-size: 0.55rem;
        letter-spacing: 0.18em; color: var(--cyan);
        margin-bottom: 4px; padding-left: 2px;
      }
      #sp-minimap {
        width: 100%; height: 148px;
        display: block;
        border: 1px solid var(--line);
        background: rgba(4, 12, 22, 0.9);
        box-shadow: 0 0 20px rgba(0, 232, 255, 0.08);
      }

      .sp-readout {
        position: absolute; left: 36px; bottom: 40px;
        font-family: var(--font-m); font-size: 0.62rem;
        pointer-events: none; max-width: 42vw;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        color: var(--cyan-dim);
        letter-spacing: 0.04em;
      }
      .sp-speed {
        position: absolute; right: 14px; bottom: 40px;
        font-family: var(--font-m); font-size: 0.64rem;
        color: var(--cyan);
        pointer-events: none;
        text-shadow: 0 0 10px var(--cyan-glow);
      }

      @media (max-width: 760px) {
        .sp-meta { display: none; }
        .sp-rail { width: 100%; grid-template-columns: 1fr; max-height: 50vh; overflow-y: auto; }
        .sp-drawer-left .sp-drawer-body { width: 72px; }
        .sp-pick span { display: none; }
        .sp-thumb, .sp-thumb-swatch { width: 28px; height: 28px; }
        .sp-drawer-bottom { left: 8px; right: 8px; transform: translateX(0) translateY(0); }
        .sp-drawer-bottom.is-collapsed { transform: translateX(0) translateY(calc(100% - var(--drawer-tab))); }
        .sp-star-panel-grid { grid-template-columns: repeat(2, 1fr); }
        .sp-minimap-wrap { width: 120px; top: 48px; right: 6px; }
        #sp-minimap { height: 110px; }
        .sp-readout { left: 34px; bottom: 36px; max-width: 55vw; }
        .sp-speed { bottom: 36px; font-size: 0.58rem; }
      }
    </style>
  </head>
  <body>
    <canvas id="space-canvas"></canvas>

    <div id="space-hud" data-scale="solar" data-rail="bodies">
      <header class="sp-zone sp-top sp-corners">
        <strong class="sp-title sp-muted">轻星图</strong>
        <div class="sp-meta sp-muted" id="sp-meta">SYS ONLINE</div>
        <div class="sp-top-btns">
          <button type="button" class="sp-btn sp-muted" id="sp-tour">自动游览</button>
          <button type="button" class="sp-btn sp-muted" id="sp-return-sol" style="display:none">返回太阳系</button>
          <a class="sp-btn sp-muted" href="/tools/astro-today">今日星空</a>
          <a class="sp-btn sp-muted" href="/tools/orbit-lab">轨道实验</a>
          <a class="sp-btn sp-muted" href="/">返回</a>
        </div>
      </header>

      <!-- 战术星图 -->
      <div class="sp-minimap-wrap sp-corners">
        <div class="sp-minimap-label sp-muted">TAC MAP</div>
        <canvas id="sp-minimap" width="168" height="148"></canvas>
      </div>

      <!-- 左侧：天体 / 星域（默认展开，点侧签折叠） -->
      <aside class="sp-drawer sp-drawer-left sp-zone sp-corners" id="sp-drawer-left" tabindex="-1">
        <button type="button" class="sp-drawer-tab sp-muted" id="sp-tab-left" aria-label="折叠侧栏">天体</button>
        <div class="sp-drawer-body sp-rail-split">
          <div class="sp-rail-modes" role="tablist" aria-label="切换列表">
            <button type="button" data-rail-mode="bodies" class="is-on">天体</button>
            <button type="button" data-rail-mode="stars">星域</button>
          </div>
          <nav class="sp-rail" id="sp-rail" aria-label="天体">
            {PRIMARY.map((b) => (
              <div class="sp-cell" data-parent={b.id}>
                <button type="button" class="sp-pick" data-goto={b.id} data-id={b.id}>
                  {TEX[b.id] ? (
                    <img class="sp-thumb" src={TEX[b.id]} alt={b.name} width="32" height="32" loading="eager" />
                  ) : (
                    <span class="sp-thumb-swatch" style={`background:${hexColor(b.color)}`} title={b.name} />
                  )}
                  <span class="sp-name sp-muted">{b.name}</span>
                </button>
                {moonsOf(b.id).length > 0 && (
                  <div class="sp-moon-pack" data-parent={b.id} title={`${b.name}的卫星`}>
                    {moonsOf(b.id).map((m) => (
                      <button
                        type="button"
                        class="sp-moon-chip"
                        data-goto={m.id}
                        data-id={m.id}
                        title={m.name}
                        aria-label={m.name}
                      >
                        <span class="sp-moon-dot" style={`background:${hexColor(m.color)}`} />
                      </button>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </nav>
          <nav id="sp-rail-stars" aria-label="邻近恒星">
            {DEST_STARS.map((s) => (
              <button
                type="button"
                class="sp-star-pick"
                data-goto-star={s.id}
                data-star={s.id}
                title={`${s.nameZh} · ${s.distLy.toFixed(2)} ly`}
              >
                <span class="sp-star-dot" style={`background:${hexColor(s.color)};color:${hexColor(s.color)}`} />
                <span class="sp-name sp-muted">{s.nameZh}</span>
              </button>
            ))}
          </nav>
        </div>
      </aside>

      <!-- 底部：默认展开，点标签折叠 -->
      <footer class="sp-drawer sp-drawer-bottom" id="sp-drawer-bottom" tabindex="-1">
        <button type="button" class="sp-drawer-tab sp-muted" id="sp-tab-bottom" aria-label="折叠控制台">控制台</button>
        <div class="sp-drawer-body sp-dock">
          <div class="sp-seg">
            <button type="button" data-mode="observe" class="sp-muted is-on">观察</button>
            <button type="button" data-mode="fly" class="sp-muted">巡航</button>
          </div>
          <button type="button" class="sp-btn sp-muted" id="sp-face-sun">面向太阳</button>
          <label class="sp-field sp-muted">时间
            <select id="sp-time">
              {TIME_PRESETS.map((t) => <option value={t.mult}>{t.label}</option>)}
            </select>
          </label>
          <label class="sp-field sp-muted">航速
            <select id="sp-speed">
              {SPEED_PRESETS.map((s) => <option value={s.mult}>{s.label}</option>)}
            </select>
          </label>
          <label class="sp-field sp-muted"><input type="checkbox" id="sp-orbits" checked /> 轨道</label>
          <label class="sp-field sp-muted">历元
            <input type="datetime-local" id="sp-date" />
          </label>
        </div>
      </footer>

      <div class="sp-readout sp-muted" id="sp-info"></div>
      <div class="sp-speed sp-muted" id="sp-speed-read"></div>
    </div>

    <script>
      import { bootSpace } from '../../scripts/space/main.ts';
      bootSpace();
    </script>
  </body>
</html>

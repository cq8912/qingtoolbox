---
import BaseLayout from '../layouts/BaseLayout.astro';
import tools from '../data/tools.json';
import categories from '../data/categories.json';

function toolHref(t: { slug: string; path?: string }) {
  return t.path || `/tools/${t.slug}`;
}

// 按分类分组工具
const grouped = categories.map((cat) => ({
  ...cat,
  tools: tools.filter((t) => t.category == cat.id),
})).filter((g) => g.tools.length > 0);
---

<BaseLayout
  title="轻工具箱"
  description="免费在线工具：JSON 查看器、时间戳转换、Base64 编解码、MD5 加密、图片合并压缩。浏览器本地处理，安全快速。"
  wide={true}
>
  <div class="home-content">
    <section class="home-intro">
      <div>
        <h1>轻工具箱</h1>
        <p>常用开发与生活小工具，本地运行，安全快速。</p>
      </div>
      <div class="home-badges">
        <span>本地处理</span>
        <span>免费实用</span>
        <span>轻量高效</span>
      </div>
    </section>

    {grouped.map((group) => (
      <section class="tool-category">
        <h2 class="category-title">{group.name}</h2>
        <div class="tool-grid">
          {group.tools.map((tool) => (
            <a href={toolHref(tool)} class="tool-card">
              <div class="icon">{tool.icon}</div>
              <div class="tool-card-body">
                <h3>{tool.name}</h3>
                <p>{tool.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

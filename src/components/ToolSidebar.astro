---
import tools from '../data/tools.json';
interface Props { currentSlug: string; }
const { currentSlug } = Astro.props;
---

<nav class="tool-sidebar-mobile" aria-label="工具导航">
  {tools.map((t) => (
    <a href={`/tools/${t.slug}`} class={t.slug == currentSlug ? 'active' : ''}>{t.name}</a>
  ))}
</nav>
<aside class="tool-sidebar" aria-label="工具导航">
  <div class="tool-sidebar-title">全部工具</div>
  {tools.map((t) => (
    <a href={`/tools/${t.slug}`} class={t.slug == currentSlug ? 'active' : ''}>{t.name}</a>
  ))}
</aside>

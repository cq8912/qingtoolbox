---
import BaseLayout from './BaseLayout.astro';
import InternalLinks from '../components/InternalLinks.astro';

interface Props {
  title: string;
  description: string;
  currentSlug: string;
}

const { title, description, currentSlug } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="tool-page">
    <slot name="header" />
    <slot />
    <section class="section">
      <h2>相关工具</h2>
      <InternalLinks currentSlug={currentSlug} />
    </section>
  </article>
</BaseLayout>

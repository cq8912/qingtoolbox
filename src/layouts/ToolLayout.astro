---
import BaseLayout from './BaseLayout.astro';
import tools from '../data/tools.json';
interface Props { title: string; description: string; currentSlug: string; }
const { title, description, currentSlug } = Astro.props;

function toolHref(t: { slug: string; path?: string }) {
  return t.path || `/tools/${t.slug}`;
}
---

<BaseLayout title={title} description={description} wide={true}>
  <div class="tool-layout">
    <aside class="tool-sidebar is-collapsed" id="tool-sidebar" aria-label="工具导航">
      <div class="tool-sidebar-head">
        <div class="tool-sidebar-title">全部工具</div>
        <button
          type="button"
          class="tool-sidebar-toggle"
          id="tool-sidebar-toggle"
          aria-expanded="false"
          aria-controls="tool-sidebar-nav"
          title="展开工具列表"
        >
          <span class="tool-sidebar-toggle-icon" aria-hidden="true">»</span>
          <span class="visually-hidden" id="tool-sidebar-toggle-label">展开</span>
        </button>
      </div>
      <nav class="tool-sidebar-nav" id="tool-sidebar-nav">
        {tools.map((t) => (
          <a
            href={toolHref(t)}
            class={t.slug == currentSlug ? 'active' : ''}
            title={t.name}
            aria-label={t.name}
            aria-current={t.slug == currentSlug ? 'page' : undefined}
          >
            <span class="tool-mini-icon" aria-hidden="true">{t.icon}</span>
            <span class="tool-mini-name">{t.name}</span>
          </a>
        ))}
      </nav>
    </aside>

    <article class="tool-main tool-page">
      <div class="tool-sidebar-mobile" aria-label="工具快速切换">
        <div class="tool-sidebar-mobile-title">全部工具</div>
        <div class="tool-sidebar-mobile-list">
          {tools.map((t) => (
            <a
              href={toolHref(t)}
              class={t.slug == currentSlug ? 'active' : ''}
              aria-current={t.slug == currentSlug ? 'page' : undefined}
            >
              {t.name}
            </a>
          ))}
        </div>
      </div>
      <slot name="header" />
      <slot />
    </article>
  </div>
</BaseLayout>

<script>
  // 桌面侧栏：默认收起，偏好写入 localStorage
  const KEY = 'tool-sidebar-expanded';
  const aside = document.getElementById('tool-sidebar');
  const btn = document.getElementById('tool-sidebar-toggle');
  const label = document.getElementById('tool-sidebar-toggle-label');
  if (aside && btn) {
    const icon = btn.querySelector('.tool-sidebar-toggle-icon');

    const apply = (expanded: boolean) => {
      aside.classList.toggle('is-collapsed', !expanded);
      aside.classList.toggle('is-expanded', expanded);
      btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      btn.title = expanded ? '收起工具列表' : '展开工具列表';
      if (label) label.textContent = expanded ? '收起' : '展开';
      if (icon) icon.textContent = expanded ? '«' : '»';
    };

    // 读偏好：仅 '1' 视为展开，其余默认收起
    apply(localStorage.getItem(KEY) == '1');

    btn.addEventListener('click', () => {
      const next = aside.classList.contains('is-collapsed');
      apply(next);
      localStorage.setItem(KEY, next ? '1' : '0');
    });

    document.addEventListener('keydown', (e) => {
      if (e.key == 'Escape' && aside.classList.contains('is-expanded')) {
        apply(false);
        localStorage.setItem(KEY, '0');
      }
    });
  }
</script>
